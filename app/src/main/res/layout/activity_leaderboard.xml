<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/menu_bg">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFDF5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="LEADERBOARD"
                android:textColor="#E53935"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TableLayout
                android:id="@+id/table_leaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1,2,3"
                android:layout_marginBottom="16dp">

                <TableRow android:layout_marginBottom="8dp">
                    <TextView android:text="#" android:textStyle="bold" android:textColor="#555555" android:textSize="14sp" android:padding="4dp"/>
                    <TextView android:text="Score" android:textStyle="bold" android:textColor="#555555" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:text="Distance" android:textStyle="bold" android:textColor="#555555" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                    <TextView android:text="Location" android:textStyle="bold" android:textColor="#555555" android:textSize="14sp" android:gravity="center" android:padding="4dp"/>
                </TableRow>

            </TableLayout>

            <Button
                android:id="@+id/btn_back_to_menu"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="BACK TO MENU"
                android:textColor="#0D47A1"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#FFD54F"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>